{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Beamview",
  "version": "0.2.0",
  "identifier": "com.beamview.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Beamview",
        "width": 1280,
        "height": 720,
        "minWidth": 640,
        "minHeight": 360,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Entertainment",
    "shortDescription": "Low-latency capture card viewer",
    "longDescription": "View your gaming console on your Mac with minimal latency. Beamview streams HDMI capture card input to your desktop through the browser's MediaDevices API, using a Tauri shell for persistence and window chrome.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "13.0",
      "exceptionDomain": "",
      "entitlements": null,
      "providerShortName": null
    }
  }
}
